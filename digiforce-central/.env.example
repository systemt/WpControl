PORT=4000
NODE_ENV=development
APP_NAME=DigiForce Central
APP_VERSION=1.2.0
APP_URL=http://localhost:4000
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/digiforce_central?schema=public
CORS_ORIGIN=*

# Agent communication (step 2)
AGENT_HEARTBEAT_INTERVAL_MINUTES=60
AGENT_SYNC_INTERVAL_MINUTES=360
AGENT_REPLAY_WINDOW_SECONDS=300
