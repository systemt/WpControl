PORT=4000
NODE_ENV=development
APP_NAME=DigiForce Central
APP_VERSION=1.7.0
APP_URL=http://localhost:4000
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/digiforce_central?schema=public
CORS_ORIGIN=*

# Agent communication
AGENT_HEARTBEAT_INTERVAL_MINUTES=60
AGENT_SYNC_INTERVAL_MINUTES=360
AGENT_REPLAY_WINDOW_SECONDS=300
AGENT_COMMAND_TIMEOUT_MS=45000

# Command queue worker (in-process, DB-backed)
COMMAND_WORKER_ENABLED=true
COMMAND_WORKER_POLL_MS=2000
COMMAND_WORKER_BATCH_SIZE=5
COMMAND_WORKER_STALE_LOCK_MS=300000

# Billing (leave STRIPE_SECRET_KEY empty to use the mock provider)
BILLING_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# Signup / trial
DEFAULT_TRIAL_PLAN_SLUG=starter
DEFAULT_TRIAL_DAYS=14
