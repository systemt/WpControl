generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Tenancy: a single `User` model covers regular account holders + super admins.
// Role-gated features are enforced in middleware, not in the schema.
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("user") // "user" | "admin"
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sites        Site[]
  commands     SiteCommand[]
  subscription Subscription?

  @@map("users")
}

// ---------------------------------------------------------------------------
// Billing: plans + subscriptions
// ---------------------------------------------------------------------------

model Plan {
  id             String   @id @default(cuid())
  slug           String   @unique           // starter | pro | agency
  name           String
  description    String?
  maxSites       Int?                       // null = unlimited
  priceMonthly   Int                        // stored in minor units (cents)
  currency       String   @default("USD")
  features       Json                       // ["Priority support", "…"]
  isPublic       Boolean  @default(true)    // hide internal/legacy plans
  sortOrder      Int      @default(0)
  providerPriceId String?                   // Stripe price id (optional)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions  Subscription[]

  @@map("plans")
}

model Subscription {
  id                      String    @id @default(cuid())
  userId                  String    @unique
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                  String
  plan                    Plan      @relation(fields: [planId], references: [id])

  // Lifecycle status mirrored from the billing provider.
  // active | trialing | past_due | canceled | incomplete | incomplete_expired
  status                  String    @default("trialing")

  provider                String    @default("mock") // mock | stripe
  providerCustomerId      String?
  providerSubscriptionId  String?

  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean   @default(false)
  canceledAt              DateTime?
  trialEndsAt             DateTime?

  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([status])
  @@map("subscriptions")
}

// ---------------------------------------------------------------------------
// Fleet: Sites are now owned by a User.
// ---------------------------------------------------------------------------

model Site {
  id            String    @id @default(cuid())
  uuid          String    @unique
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  url           String
  environment   String    @default("production")
  status        String    @default("unknown")
  centralNotes  String?
  wpVersion     String?
  phpVersion    String?
  pluginVersion String?
  lastSeenAt    DateTime?
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  connection      SiteConnection?
  logs            SiteLog[]
  commands        SiteCommand[]
  pluginSnapshots SitePluginSnapshot[]
  themeSnapshots  SiteThemeSnapshot[]
  coreSnapshot    SiteCoreSnapshot?

  @@index([userId])
  @@index([status])
  @@index([environment])
  @@map("sites")
}

model SiteConnection {
  id                    String   @id @default(cuid())
  siteId                String   @unique
  site                  Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  secretKeyEncrypted    String
  allowedIps            String[] @default([])
  requireSignedRequests Boolean  @default(true)
  connectionEnabled     Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("site_connections")
}

model SiteLog {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  level     String
  category  String
  message   String
  metaJson  Json?
  createdAt DateTime @default(now())

  @@index([siteId, createdAt])
  @@index([level])
  @@index([category])
  @@map("site_logs")
}

model SiteCommand {
  id           String    @id @default(cuid())
  siteId       String
  site         Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  userId       String?                                  // who initiated (null = system / cron)
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  commandId    String    @unique
  action       String
  payloadJson  Json
  status       String    @default("pending")            // pending | processing | succeeded | failed | cancelled
  responseJson Json?
  errorCode    String?
  errorMessage String?

  // Queue + retry bookkeeping
  attempt           Int       @default(1)               // 1 = initial, 2+ = retry of a prior command
  parentCommandId   String?                             // SiteCommand.id of the row this is a retry of
  lockedAt          DateTime?                           // when a worker claimed it (status=processing)
  lockedBy          String?                             // worker identifier (hostname:pid)

  createdAt    DateTime  @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?

  @@index([siteId, status])
  @@index([status, createdAt])
  @@index([status, lockedAt])
  @@index([parentCommandId])
  @@index([userId])
  @@map("site_commands")
}

model SitePluginSnapshot {
  id                String   @id @default(cuid())
  siteId            String
  site              Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pluginFile        String
  slug              String?
  name              String?
  versionInstalled  String?
  versionAvailable  String?
  hasUpdate         Boolean  @default(false)
  isActive          Boolean  @default(false)
  autoUpdateEnabled Boolean  @default(false)
  author            String?
  requiresWp        String?
  requiresPhp       String?
  lastSyncedAt      DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([siteId, pluginFile])
  @@index([siteId, hasUpdate])
  @@index([siteId, isActive])
  @@map("site_plugin_snapshots")
}

model SiteThemeSnapshot {
  id                String   @id @default(cuid())
  siteId            String
  site              Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  stylesheet        String
  template          String?
  name              String?
  versionInstalled  String?
  versionAvailable  String?
  hasUpdate         Boolean  @default(false)
  isActive          Boolean  @default(false)
  autoUpdateEnabled Boolean  @default(false)
  lastSyncedAt      DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([siteId, stylesheet])
  @@index([siteId, hasUpdate])
  @@map("site_theme_snapshots")
}

// ---------------------------------------------------------------------------
// System-level audit log (not site-scoped). Currently records impersonation
// start/stop; future admin actions (plan overrides, user disable, …) land here.
// ---------------------------------------------------------------------------
model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?                         // who performed the action
  targetUserId String?                         // who it was done to (nullable)
  action       String                          // impersonation_start | impersonation_stop | …
  meta         Json?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model SiteCoreSnapshot {
  id             String   @id @default(cuid())
  siteId         String   @unique
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  currentVersion String
  latestVersion  String
  hasUpdate      Boolean  @default(false)
  updateType     String?
  lastSyncedAt   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("site_core_snapshots")
}
