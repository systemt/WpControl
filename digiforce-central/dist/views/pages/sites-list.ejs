<%- include('../partials/head', { title: title + ' — ' + appName }) %>
<body>
  <%- include('../partials/navbar') %>
  <div class="layout">
    <%- include('../partials/sidebar') %>
    <main class="content">
      <%- include('../partials/page-header', {
        title: 'Sites',
        subtitle: sites.length + ' site' + (sites.length === 1 ? '' : 's'),
        actions: [{ href: '/admin/sites/new', label: '+ New site', primary: true }],
      }) %>

      <%- include('../partials/flash') %>

      <form method="get" action="/admin/sites" class="toolbar">
        <input
          type="search"
          name="q"
          placeholder="Search by name or URL"
          value="<%= filters.q %>"
        />
        <select name="status">
          <option value="">All statuses</option>
          <% statusOptions.forEach(function (s) { %>
            <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option>
          <% }); %>
        </select>
        <select name="env">
          <option value="">All environments</option>
          <% envOptions.forEach(function (e) { %>
            <option value="<%= e %>" <%= filters.environment === e ? 'selected' : '' %>><%= e %></option>
          <% }); %>
        </select>
        <button class="btn" type="submit">Apply</button>
        <% if (filters.q || filters.status || filters.environment) { %>
          <a class="btn btn-ghost" href="/admin/sites">Reset</a>
        <% } %>
      </form>

      <section class="panel">
        <% if (sites.length === 0) { %>
          <div class="empty-state">
            <p><strong>No sites match the current filters.</strong></p>
            <% if (filters.q || filters.status || filters.environment) { %>
              <p>Try clearing the filters or <a href="/admin/sites">view all sites</a>.</p>
            <% } else { %>
              <p><a href="/admin/sites/new" class="btn btn-primary btn-small">Provision your first site</a></p>
            <% } %>
          </div>
        <% } else { %>
          <div class="table-scroll">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>URL</th>
                  <th>Env</th>
                  <th>Status</th>
                  <th>WP</th>
                  <th>PHP</th>
                  <th>Plugin</th>
                  <th>Last seen</th>
                  <th>Last sync</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% sites.forEach(function (s) { %>
                  <tr>
                    <td><a href="/admin/sites/<%= s.id %>"><%= s.name %></a></td>
                    <td class="muted"><%= s.url %></td>
                    <td><%= s.environment %></td>
                    <td><span class="badge badge-<%= s.status %>"><%= s.status %></span></td>
                    <td><%= s.wpVersion || '—' %></td>
                    <td><%= s.phpVersion || '—' %></td>
                    <td><%= s.pluginVersion || '—' %></td>
                    <td><%= formatRelative(s.lastSeenAt) %></td>
                    <td><%= formatRelative(s.lastSyncAt) %></td>
                    <td><a class="btn btn-small" href="/admin/sites/<%= s.id %>">View</a></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </main>
  </div>
  <%- include('../partials/footer') %>
</body>
</html>
